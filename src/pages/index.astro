---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Terminal from '@/components/Terminal.astro';
---

<BaseLayout
  title="Home"
  description="Isaac Dessert — Lead Software Engineer. Building things that matter."
>
  <section class="min-h-[calc(100vh-4rem)] flex items-center relative overflow-hidden">
    <!-- Decorative grid -->
    <div class="absolute inset-0 -z-10 pointer-events-none opacity-5" aria-hidden="true">
      <div class="absolute inset-0"
        style="background-image: linear-gradient(#f5e642 1px, transparent 1px), linear-gradient(to right, #f5e642 1px, transparent 1px); background-size: 60px 60px;">
      </div>
    </div>

    <div class="max-w-5xl mx-auto px-6 py-24 w-full">
      <div class="flex flex-col lg:flex-row items-start gap-16">

        <!-- Left: Hero copy -->
        <div class="flex-1 min-w-0">
          <p class="font-mono text-accent-green text-sm mb-4 tracking-widest uppercase">
            Hello, I'm
          </p>
          <h1 class="font-mono font-bold text-6xl md:text-7xl lg:text-8xl text-accent-yellow leading-none mb-4">
            Isaac<br />Dessert
          </h1>
          <h2 class="font-mono text-xl md:text-2xl text-text-muted mb-8">
            <span class="text-accent-green">Lead Software Engineer</span>
          </h2>
          <p class="text-text-primary text-lg leading-relaxed mb-12 max-w-xl">
            I build robust systems, lead engineering teams, and write about what I learn along the way.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/portfolio/about" class="btn-primary">About Me</a>
            <a href="/portfolio/projects" class="btn-secondary">View Projects</a>
            <a href="/portfolio/blog" class="btn-secondary">Read Blog</a>
            <a href="/portfolio/reading" class="btn-secondary">Reading List</a>
          </div>
        </div>

        <!-- Right: Terminal -->
        <div class="w-full lg:w-auto lg:flex-1">
          <Terminal />
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
