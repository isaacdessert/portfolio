---
import BaseLayout from '@/layouts/BaseLayout.astro';

const skills = {
  'Languages': ['TypeScript', 'JavaScript', 'Python', 'Go', 'SQL'],
  'Frontend': ['React', 'Astro', 'Next.js', 'Tailwind CSS'],
  'Backend': ['Node.js', 'Express', 'FastAPI', 'PostgreSQL', 'Redis'],
  'DevOps': ['Docker', 'Kubernetes', 'GitHub Actions', 'AWS', 'Terraform'],
  'Tools': ['Git', 'Linux', 'VS Code', 'Figma'],
};

const experience = [
  {
    title: 'Lead Software Engineer',
    company: 'Your Company',
    period: '2022 — Present',
    description: 'Leading a team of engineers to build and scale core platform infrastructure. Driving technical roadmap, architecture decisions, and engineering culture.',
    highlights: [
      'Scaled platform to handle 10x traffic growth',
      'Built and mentored a team of 5 engineers',
      'Reduced deployment time by 60% via CI/CD improvements',
    ],
  },
  {
    title: 'Senior Software Engineer',
    company: 'Previous Company',
    period: '2019 — 2022',
    description: 'Full-stack development across multiple product areas with a focus on performance and reliability.',
    highlights: [
      'Architected a microservices migration from a monolith',
      'Improved API response times by 40%',
      'Maintained 99.9% uptime across critical services',
    ],
  },
  {
    title: 'Software Engineer',
    company: 'Earlier Company',
    period: '2017 — 2019',
    description: 'Early career role building customer-facing features and internal tooling.',
    highlights: [
      'Delivered 3 major product features end-to-end',
      'Built internal dashboards used by 200+ employees',
    ],
  },
];

const education = [
  {
    degree: 'B.S. Computer Science',
    school: 'Your University',
    year: '2017',
  },
];
---

<BaseLayout
  title="About"
  description="About Isaac Dessert — Lead Software Engineer. Resume, skills, and experience."
>
  <div class="max-w-5xl mx-auto px-6 py-20">
    <header class="mb-16">
      <h1 class="section-heading">About Me</h1>
      <p class="section-subheading">// who I am + what I've built</p>
      <p class="text-text-primary text-lg leading-relaxed max-w-2xl">
        I'm a Lead Software Engineer with 8+ years of experience building scalable web systems
        and leading high-performing teams. I care deeply about code quality, developer experience,
        and shipping things that actually work.
      </p>
    </header>

    <div class="grid md:grid-cols-3 gap-12">
      <!-- Sidebar -->
      <aside class="md:col-span-1 space-y-10">
        <!-- Skills -->
        <div>
          <h2 class="font-mono text-accent-green text-sm uppercase tracking-widest mb-4">Skills</h2>
          <div class="space-y-4">
            {Object.entries(skills).map(([category, items]) => (
              <div>
                <p class="font-mono text-xs text-text-muted mb-2">{category}</p>
                <div class="flex flex-wrap gap-1.5">
                  {items.map(skill => (
                    <span class="tag">{skill}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Education -->
        <div>
          <h2 class="font-mono text-accent-green text-sm uppercase tracking-widest mb-4">Education</h2>
          {education.map(edu => (
            <div>
              <p class="font-mono text-text-primary text-sm font-semibold">{edu.degree}</p>
              <p class="font-mono text-text-muted text-xs">{edu.school}</p>
              <p class="font-mono text-text-muted text-xs">{edu.year}</p>
            </div>
          ))}
        </div>

        <!-- Contact -->
        <div>
          <h2 class="font-mono text-accent-green text-sm uppercase tracking-widest mb-4">Contact</h2>
          <div class="space-y-2">
            <a href="mailto:isaac@example.com" class="font-mono text-sm text-text-muted hover:text-accent-yellow transition-colors block">
              isaac@example.com
            </a>
            <a href="https://github.com/isaacdessert" target="_blank" rel="noopener noreferrer" class="font-mono text-sm text-text-muted hover:text-accent-yellow transition-colors block">
              github.com/isaacdessert
            </a>
            <a href="https://linkedin.com/in/isaacdessert" target="_blank" rel="noopener noreferrer" class="font-mono text-sm text-text-muted hover:text-accent-yellow transition-colors block">
              linkedin.com/in/isaacdessert
            </a>
          </div>
        </div>
      </aside>

      <!-- Experience timeline -->
      <div class="md:col-span-2">
        <h2 class="font-mono text-accent-green text-sm uppercase tracking-widest mb-8">Experience</h2>
        <div class="relative">
          <!-- Timeline line -->
          <div class="absolute left-0 top-2 bottom-0 w-px bg-accent-yellow/30" aria-hidden="true"></div>

          <div class="space-y-12">
            {experience.map((job) => (
              <div class="pl-8 relative">
                <!-- Timeline dot -->
                <div class="absolute left-[-4px] top-2 w-2 h-2 rounded-full bg-accent-yellow" aria-hidden="true"></div>

                <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
                  <div>
                    <h3 class="font-mono font-semibold text-text-primary">{job.title}</h3>
                    <p class="font-mono text-accent-yellow text-sm">{job.company}</p>
                  </div>
                  <span class="font-mono text-xs text-text-muted whitespace-nowrap">{job.period}</span>
                </div>

                <p class="text-text-muted text-sm leading-relaxed mb-3">{job.description}</p>

                <ul class="space-y-1">
                  {job.highlights.map(h => (
                    <li class="flex items-start gap-2 text-sm text-text-muted">
                      <span class="text-accent-green mt-0.5 shrink-0">▸</span>
                      {h}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
