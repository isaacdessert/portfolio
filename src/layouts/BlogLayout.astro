---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  tags?: string[];
  excerpt?: string;
  readTime?: number;
}

const { title, date, tags = [], excerpt, readTime } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={excerpt}>
  <article class="max-w-2xl mx-auto px-6 py-20">
    <a
      href="/blog"
      class="inline-flex items-center gap-2 font-mono text-sm text-text-muted hover:text-accent-yellow transition-colors mb-10"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to blog
    </a>

    <header class="mb-12">
      <h1 class="text-4xl font-bold text-accent-yellow font-mono leading-tight mb-4">
        {title}
      </h1>
      <div class="flex flex-wrap items-center gap-4 text-sm font-mono text-text-muted">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {readTime && <span>{readTime} min read</span>}
      </div>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-invert max-w-none
                prose-headings:font-mono
                prose-a:text-accent-yellow prose-a:no-underline hover:prose-a:underline
                prose-code:text-accent-green prose-code:bg-bg-surface prose-code:px-1 prose-code:rounded
                prose-pre:bg-bg-surface prose-pre:border prose-pre:border-bg-surface
                prose-blockquote:border-l-accent-yellow prose-blockquote:text-text-muted
                prose-strong:text-text-primary
                prose-hr:border-bg-surface">
      <slot />
    </div>
  </article>
</BaseLayout>
