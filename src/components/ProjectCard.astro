---
interface Props {
  name: string;
  description: string | null;
  language: string | null;
  stars: number;
  url: string;
  featured?: boolean;
  updatedAt: string;
}

const { name, description, language, stars, url, featured = false, updatedAt } = Astro.props;

const langColors: Record<string, string> = {
  TypeScript: 'text-blue-400',
  JavaScript: 'text-yellow-300',
  Python: 'text-green-400',
  Go: 'text-cyan-400',
  Rust: 'text-orange-400',
  Ruby: 'text-red-400',
  Java: 'text-orange-300',
  'C++': 'text-pink-400',
  C: 'text-gray-400',
  Shell: 'text-accent-green',
};

const langColor = language ? (langColors[language] ?? 'text-text-muted') : 'text-text-muted';

const updated = new Date(updatedAt).toLocaleDateString('en-US', {
  month: 'short',
  year: 'numeric',
});
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="group block bg-bg-surface border border-bg-surface hover:border-accent-yellow transition-colors duration-200 p-6 rounded-sm"
>
  <div class="flex items-start justify-between gap-4 mb-3">
    <div class="flex items-center gap-2 min-w-0">
      {featured && (
        <span class="shrink-0 text-[10px] font-mono px-1.5 py-0.5 border border-accent-yellow text-accent-yellow rounded">
          featured
        </span>
      )}
      <h3 class="font-mono font-semibold text-text-primary group-hover:text-accent-yellow transition-colors truncate">
        {name}
      </h3>
    </div>
    <svg class="w-4 h-4 text-text-muted group-hover:text-accent-yellow transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
    </svg>
  </div>

  <p class="text-sm text-text-muted leading-relaxed mb-4 line-clamp-2 min-h-[2.5rem]">
    {description ?? 'No description provided.'}
  </p>

  <div class="flex items-center gap-4 text-xs font-mono text-text-muted">
    {language && (
      <span class:list={['flex items-center gap-1.5', langColor]}>
        <span class="w-2 h-2 rounded-full bg-current" aria-hidden="true"></span>
        {language}
      </span>
    )}
    {stars > 0 && (
      <span class="flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        {stars}
      </span>
    )}
    <span class="ml-auto">{updated}</span>
  </div>
</a>
