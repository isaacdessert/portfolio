---
const navLinks = [
  { label: 'About', href: '/portfolio/about' },
  { label: 'Projects', href: '/portfolio/projects' },
  { label: 'Blog', href: '/portfolio/blog' },
];

const currentPath = Astro.url.pathname;
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-bg-primary/90 backdrop-blur-sm border-b border-bg-surface">
  <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/portfolio/" class="font-mono font-semibold text-accent-yellow hover:text-white transition-colors">
      id<span class="text-accent-green">.</span>dev
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[
              'font-mono text-sm transition-colors hover:text-accent-yellow',
              currentPath.startsWith(link.href)
                ? 'text-accent-yellow'
                : 'text-text-muted'
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden text-text-muted hover:text-accent-yellow transition-colors"
      aria-label="Toggle menu"
    >
      <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-bg-surface">
    <ul class="max-w-5xl mx-auto px-6 py-4 flex flex-col gap-4">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[
              'font-mono text-sm transition-colors hover:text-accent-yellow block',
              currentPath.startsWith(link.href)
                ? 'text-accent-yellow'
                : 'text-text-muted'
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });
</script>
